{
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "api",
            "resources": {
              "requests": {
                "cpu": "200m",
                "memory": "512Mi"
              },
              "limits": {
                "cpu": "1000m",
                "memory": "1Gi"
              }
            },
            "startupProbe": {
              "tcpSocket": {
                "port": 8000
              },
              "failureThreshold": 30,
              "periodSeconds": 5,
              "timeoutSeconds": 1
            },
            "readinessProbe": {
              "tcpSocket": {
                "port": 8000
              },
              "initialDelaySeconds": 5,
              "periodSeconds": 10,
              "timeoutSeconds": 1,
              "failureThreshold": 3
            },
            "livenessProbe": {
              "tcpSocket": {
                "port": 8000
              },
              "initialDelaySeconds": 20,
              "periodSeconds": 20,
              "timeoutSeconds": 1,
              "failureThreshold": 3
            }
          }
        ]
      }
    }
  }
}
